{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "course-schema.json",
  "title": "Course Structure with Schedule",
  "type": "object",
  "required": ["course", "schedule"],

  "properties": {
    "course": {
      "type": "object",
      "required": ["name", "units"],
      "additionalProperties": false,

      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },

        "units": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/unit"
          }
        }
      }
    },

    "schedule": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/week"
      }
    }
  },

  "$defs": {
    "unit": {
      "type": "object",
      "required": ["id", "name", "topics"],
      "additionalProperties": false,

      "properties": {
        "id": {
          "type": "string",
          "pattern": "^U[0-9]+$"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "topics": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/topic"
          }
        }
      }
    },

    "topic": {
      "type": "object",
      "required": ["id", "name"],
      "additionalProperties": false,

      "properties": {
        "id": {
          "type": "string",
          "pattern": "^T[0-9]+$"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "parts": {
          "type": "integer",
          "minimum": 1,
          "description": "Número de partes en que se divide el tema"
        }
      }
    },

    "week": {
      "type": "object",
      "required": ["week", "coverage"],
      "additionalProperties": false,

      "properties": {
        "week": {
          "type": "integer",
          "minimum": 1
        },
        "coverage": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/coverage"
          }
        }
      }
    },

    "coverage": {
      "type": "object",
      "required": ["unit", "topics"],
      "additionalProperties": false,

      "properties": {
        "unit": {
          "type": "string",
          "pattern": "^U[0-9]+$"
        },
        "topics": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/topicReference"
          }
        }
      }
    },

    "topicReference": {
      "type": "object",
      "required": ["id"],
      "additionalProperties": false,

      "properties": {
        "id": {
          "type": "string",
          "pattern": "^T[0-9]+$"
        },
        "part": {
          "type": "integer",
          "minimum": 1,
          "description": "Parte específica del tema (si aplica)"
        }
      },

      "allOf": [
        {
          "if": {
            "required": ["part"]
          },
          "then": {
            "required": ["part"]
          }
        }
      ]
    }
  }
}
