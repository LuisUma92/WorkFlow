% ==========================================================
%  Colores para magnitudes físicas
%  Derivados de la paleta institucional:
%    Azul (identidad)    → cinemática, movimiento
%    Amarillo (jerarquía) → causas dinámicas, posición
%    Verde (interacción)  → energía, conservación
% ==========================================================

% --- Espacial (familia accent: calidez dorada) ---
\definecolor{Pos} {HTML}{795A32}    % posición — marrón dorado
\definecolor{PosX}{HTML}{B05A1E}    % componente x — naranja quemado
\definecolor{PosY}{HTML}{7B2D90}    % componente y — violeta
\definecolor{PosZ}{HTML}{8A2D4A}    % componente z — granate

% --- Cinemática (familia primary: identidad azul) ---
\definecolor{Dis} {HTML}{7840A0}    % distancia — púrpura
\definecolor{Des} {HTML}{A0258A}    % desplazamiento — magenta
\definecolor{Vel} {HTML}{2B5EA6}    % velocidad — azul (≈ primaryLight)
\definecolor{Rap} {HTML}{20508A}    % rapidez — azul profundo
\definecolor{Ace} {HTML}{258750}    % aceleración — verde esmeralda

% --- Dinámica (familia accent: autoridad dorada) ---
\definecolor{Mas} {HTML}{8A6A18}    % masa — dorado oscuro (= accentPrimaryDark)
\definecolor{Fza} {HTML}{B83A30}    % fuerza — rojo autoridad

% --- Momento (puente teal: blue ↔ green) ---
\definecolor{MomL}{HTML}{1B7068}    % momento lineal — verde azulado
\definecolor{MomA}{HTML}{207888}    % momento angular — cian profundo

% --- Energía (familia primaryAlt: feedback verde) ---
\definecolor{Ene} {HTML}{2A7830}    % energía total — verde bosque
\definecolor{EneK}{HTML}{608520}    % energía cinética — verde amarillento
\definecolor{EneU}{HTML}{306830}    % energía potencial — verde oscuro

