	month = jan,
	year = {2006},
	file = {Full Text:/home/luis/Zotero/storage/T4LH2NCQ/Jasiulionis and Rožkov - 2006 - Radionuclides in deposition in the Ignalina NPP re.pdf:application/pdf},
