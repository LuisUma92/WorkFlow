@incollection{du_applications_2012,
	address = {Berlin, Heidelberg},
	title = {Applications of short-lived radionuclides ({7Be}, {210Pb}, {210Po}, {137Cs} and {234Th}) to trace the sources, transport pathways and deposition of particles/sediments in rivers, estuaries and coasts},
