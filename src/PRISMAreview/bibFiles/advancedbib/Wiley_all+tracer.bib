@incollection{kelsey_environmental_2023,
	title = {Environmental {Radiation}},
	isbn = {978-1-118-51715-4},
	url = {https://doi.org/10.1002/9781118517154.ch14},
	abstract = {Summary Environmental radiation comes from the sky, the earth, and the air we breathe and can be categorized as natural or artificial. The major sources of natural background radiation are internal, cosmic, and from rocks and dirt from the earth. The BEIR IV report estimates that radon inhalation is thought to contribute 10\% of the fatal lung cancer in the United States. Primordial and terrestrial radiation are present in rocks and soils and occur when naturally radioactive isotopes of uranium, thorium, and potassium decay within the earth's crust. There are two types of ?man-made? radiation: technology modified and technology produced by man. The total annual exposure does not include the contribution from smoking or occupational exposure. Society benefits from the use of radiation to improve health care, find defects in manufactured parts, and generate electricity.},
