	pages = {135--177},
	annote = {Wiley Online Books},
}

@incollection{salbu_speciation_2017,
	title = {Speciation of {Radionuclides} in the {Environment}},
	isbn = {978-0-470-02731-8},
	url = {https://doi.org/10.1002/9780470027318.a6308},
	abstract = {Abstract To obtain information on physicochemical forms of radionuclides in the environment, speciation techniques should be applied in situ, at-site or in laboratories shortly after sample collection. Among speciation techniques for radionuclides in waters, combined in situ ultrafiltration and exchange chromatography are most promising as radionuclides species are fractionated with respect to nominal molecular mass and change properties simultaneously. However, the fractionation and characterization of chemically well-defined low molecular mass (LMM) species in waters is still a challenge. Surface analytical techniques (e.g. electron microscopy) are useful for characterizing colloids and particles with respect to structure and radionuclide distribution. Recent development within synchrotron-based X-ray microbeam techniques allows detailed information of crystallographic structure (micro-X-ray diffraction (?-XRD)), oxidation states (micro-X-ray absorption near-edge spectroscopy (?-XANES)) and volume distribution (?-XANES tomography) of particle-associated radionuclides on the micrometer scale. Information on radionuclides reversibly or irreversibly associated with solid surfaces (binding mechanisms) is attained by different extraction techniques, while dynamic tracer experiments can provide information on the kinetics involved.},
	urldate = {2024-03-08},
	booktitle = {Encyclopedia of {Analytical} {Chemistry}},
	author = {Salbu, Brit},
	month = dec,
	year = {2017},
	doi = {10.1002/9780470027318.a6308},
	annote = {Major Reference Works},
}

