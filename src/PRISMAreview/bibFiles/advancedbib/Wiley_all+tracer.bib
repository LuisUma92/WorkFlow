	note = {Publisher: John Wiley \& Sons, Ltd},
	keywords = {biomass burning, East Asia, eolian dust, free troposphere, Pacific},
}

@incollection{amiard_origins_2005,
	title = {The {Origins} of {Radionuclides} in {Marine} {Environments}},
	isbn = {978-1-394-18609-9},
	url = {https://doi.org/10.1002/9781394186099.ch2},
	abstract = {Summary The presence of radionuclides in the marine environment has a double origin: a natural origin and an artificial origin linked to human activities. The anthropogenic origins of radioactive pollutants in the marine environment are various and varied. Some radionuclides have a dual origin, natural and anthropogenic. More than 60 radionuclides are known to occur naturally in the environment. Since World War II and the military use of nuclear energy, direct and indirect releases of radionuclides into the marine environment have been particularly significant, especially between 1945 and 1990. The use of nuclear fission as a source of energy requires a whole series of industrial operations that together form the nuclear fuel cycle. The recording of accidents of ships at sea involving radionuclides has been the subject of several censuses. Several rivers carry radionuclides of anthropogenic origin. The majority of radioactive waste has been dumped in the Atlantic and Arctic oceans.},
	urldate = {2024-03-08},
	booktitle = {Marine {Radioecology}},
	author = {Amiard, Jean-Claude},
	month = mar,
	year = {2005},
	doi = {10.1002/9781394186099.ch2},
	keywords = {radioactive waste, human activities, anthropogenic radionuclides, industrial operations, marine environment, nuclear energy, nuclear fission, nuclear fuel cycle},
	pages = {13--46},
	annote = {Wiley Online Books},
}

@article{gellis_sediment_2018,
	title = {Sediment {Fingerprinting} to {Delineate} {Sources} of {Sediment} in the {Agricultural} and {Forested} {Smith} {Creek} {Watershed}, {Virginia}, {USA}},
	volume = {54},
	issn = {9781394186099},
	url = {https://doi.org/10.1111/1752-1688.12680},
	doi = {10.1111/1752-1688.12680},
	abstract = {Abstract The sediment fingerprinting approach was used to apportion fine-grained sediment to cropland, pasture, forests, and streambanks in the agricultural and forested Smith Creek, watershed, Virginia. Smith Creek is a showcase study area in the Chesapeake Bay watershed, where management actions to reduce nutrients and sediment are being monitored. Analyses of suspended sediment at the downstream and upstream sampling sites indicated streambanks were the major source of sediment (76\% downstream and 70\% upstream). Current management strategies proposed to reduce sediment loadings for Smith Creek do not target streambanks as a source of sediment, whereas the results of this study indicate that management strategies to reduce sediment loads in Smith Creek may be effective if directed toward managing streambank erosion. The results of this study also highlight the utility of sediment fingerprinting as a management tool to identify sediment sources.},
	number = {6},
	urldate = {2024-03-08},
	journal = {JAWRA Journal of the American Water Resources Association},
	author = {Gellis, A.C. and Gorman Sanisaca, L.},
	month = dec,
	year = {2018},
	note = {Publisher: John Wiley \& Sons, Ltd},
	keywords = {Chesapeake Bay, sediment fingerprinting, bank erosion, sediment TMDL},
	pages = {1197--1221},
}

