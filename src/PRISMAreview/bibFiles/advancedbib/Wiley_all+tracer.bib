@incollection{filchev_modeling_2021,
	title = {Modeling of {Abiotic} {Stress} of {Conifers} with {Remote} {Sensing} {Data}},
	isbn = {978-1-119-78815-7},
	url = {https://doi.org/10.1002/9781119788157.ch4},
	abstract = {Summary This chapter discusses the different modeling approaches of abiotic stress in coniferous forests using remote sensing data. A detailed outlook with a background on stress, loads, and response of the conifers is provided to the readership. The chapter discusses the abiotic factors in two major groups; natural and anthropogenic. The natural abiotic factors are dealt with by natural components, i.e. soil chemical conditions. The anthropogenic factors affect almost all of the natural components; soil, atmosphere, and hydrosphere. Various aspects of atmospheric and soil pollution as well as ore extraction are provided with examples from numerous studies. The last part of the chapter is devoted to the critical loads and thresholds of various chemical constituents in soils and for conifers in specific. It also deals with the remote sensing methods and data used to discriminate them from space. Special attention is paid to the multi-band, hyperspectral, fluorescent, and thermal infrared satellite data which become more readily available to the Earth Observation community. The last part of the chapter is describing some of the most common models used in geosciences, ecology, and radiobiology which model the stress in vegetation and in conifers in particular.},
	urldate = {2024-03-08},
	booktitle = {Advances in {Remote} {Sensing} for {Forest} {Monitoring}},
	author = {Filchev, Lachezar},
	month = jun,
	year = {2021},
	doi = {10.1002/9781119788157.ch4},
	keywords = {ecology, abiotic stress, coniferous vegetation, earth observation, geosciences, radiobiology},
	pages = {78--106},
	annote = {Wiley Online Books},
}

@incollection{loveland_radiochemical_2021,
	title = {Radiochemical {Techniques}},
	isbn = {978-1-119-34845-0},
	url = {https://doi.org/10.1002/9781119348450.ch19},
	abstract = {Summary This chapter discusses the basic principles behind radiochemical techniques and some details of their application. Radiochemistry involves the application of the basic ideas of inorganic, organic, physical, and analytical chemistry to the manipulation of radioactive material. One obviously needs radioactive materials to carry out radiochemistry. The chapter summarizes the commonly used radionuclides and their methods of production. A combination of reactor and cyclotron irradiations is used to prepare most radionuclides. One of the frequent chores of radiochemists is the preparation of accelerator targets and samples for reactor irradiation. Measurement of charged-particle beam intensities is largely done using physical methods, although some older radiochemical methods are used occasionally. The most common technique to measure the intensity of a charged-particle beam is to use a Faraday cup. In the study of nuclear reactions, nuclear structure, and the heaviest elements, one frequently needs to chemically separate the nuclide(s) of interest from other radioactive species that are present.},
	urldate = {2024-03-08},
	booktitle = {Modern {Nuclear} {Chemistry}},
