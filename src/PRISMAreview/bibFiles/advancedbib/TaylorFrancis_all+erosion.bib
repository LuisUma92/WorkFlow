@article{videla_assessment_2020,
	series = {Special {Issue}: {Environmental} isotope applications in {Latin} {America} and the {Carribean} region.},
	title = {Assessment of runoff using {7Be} in vineyards in the central valley of {Chile}: {Isotopes} in {Environmental} \& {Health} {Studies}},
	volume = {56},
	issn = {1025-6016},
	shorttitle = {Assessment of runoff using {7Be} in vineyards in the central valley of {Chile}},
	url = {https://search.ebscohost.com/login.aspx?direct=true&db=cbt&AN=20219990692&lang=es&site=ehost-live&scope=site},
	doi = {10.1080/10256016.2020.1803856},
	abstract = {In Chile, erosion processes (on-site and off-site impact) affect at least 36.9 million ha-1, representing 49\% of the total land area. Different regions show severe soil degradation mainly caused by water erosion processes. The importance of sediment-associated transport and the key role of soil erosion affect the fertility of the land and the contamination of water bodies. The aim of this work was to estimate the erosion rate, caused by the rainfall in Apalta vineyards in the Libertador General Bernardo O'Higgins Region of Chile using isotope techniques, assessing the 7Be runoff during four years (2009-2012). The 7Be distribution mass depth at a reference site ranged from 7 to 24 kg m-2 in the first two centimetres soil layer. Even when the vineyards have been well managed, the topographic characteristics and the climatic conditions facilitated soil erosion, with average rates of 50.4, 23.5, 50.6 and 67.3 tons ha-1 y-1 in 2009, 2010, 2011 and 2012, respectively. The robustness of the 7Be technique demonstrated the advantage of a non-soil-destructive methodology to calculate soil distribution and erosion rates.},
	number = {5-6},
	journal = {Isotopes in Environmental \& Health Studies},
	author = {Videla, Ximena and Villegas, Daniel and Parada, Ana María and Nario, Adriana},
	month = nov,
	year = {2020},
	note = {Publisher: Taylor \& Francis},
	keywords = {Erosion, rainfall, plants, America, Pollution and Degradation, PP400, PP600, Soil and Water Conservation, Techniques and Methodology, ZZ900, Andean Group, angiosperms, APEC countries, eudicots, eukaryotes, high income countries, JJ600, Latin America, Meteorology and Climate, methods, PP500, Soil Fertility, South America, Spermatophyta, very high Human Development Index countries, Vitaceae, Vitales, Vitis},
	pages = {644--653},
	annote = {doi: 10.1080/10256016.2020.1803856},
	annote = {doi: 10.1080/10256016.2020.1803856},
	file = {EBSCO Full Text:/home/luis/Zotero/storage/TA5EMYKD/Videla et al. - 2020 - Assessment of runoff using 7Be in vineyards in the.pdf:application/pdf},
}

@article{salih_7be_2004,
	title = {{7Be} {Levels} in {Sewage} {Sludge}: {A} {Baseline} {Study}},
	volume = {32},
	issn = {1073-9149},
	url = {https://doi.org/10.1081/CI-120037675},
	doi = {10.1081/CI-120037675},
	abstract = {The radioactive beryllium (Be) levels in sewage sludge were analyzed. It was observed that the Be levels in the sludge were up to three orders of magnitude higher than the accepted level of radioactivity in domestic water supplies. 7Be activities upto 40 Bq/kg above the background were recorded and no appreciable activity was found in the liquid disinfected specimens. Analysis suggests the preparation of soil-additives from the sludge only after about 5 half-lives have elapsed.},
	language = {English},
	number = {4},
