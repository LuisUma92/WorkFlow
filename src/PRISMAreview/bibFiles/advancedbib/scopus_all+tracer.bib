	issn = {0012-821X},
	url = {https://www.sciencedirect.com/science/article/pii/0012821X88900350},
	doi = {10.1016/0012-821X(88)90035-0},
	abstract = {We describe an accelerator mass spectrometry (AMS) technique for measuring the cosmogenic isotope 7Be (half-life 53.2 days). Our detection limit of ∼ 104 atoms with this technique is ∼ 100 times lower than that obtained by γ counting. The potential advantages of this increased sensitivity, combined with AMS measurements of 10Be (half-life 1.5 My) in the same samples, are discussed in the context of the application of  7Be 10Be as a time-dependent tracer of various environmental transport processes. © 1988.},
