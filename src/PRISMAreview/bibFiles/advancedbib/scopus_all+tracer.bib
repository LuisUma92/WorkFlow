@article{raksawong_measurement_2016,
	title = {Measurement of {7Be} inventory in the outer {Songkhla} lagoon, {Thailand}},
	volume = {310},
	copyright = {2016 Akadémiai Kiadó, Budapest, Hungary},
	issn = {1588-2780},
