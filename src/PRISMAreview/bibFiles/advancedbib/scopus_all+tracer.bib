	annote = {Export Date: 08 March 2024; Cited By: 4; Correspondence Address: Y. Kanai; Geological Survey of Japan, National Institute of Advanced Industrial Science and Technology (AIST), Tsukuba, Ibaraki 305-8567, 1-1-1 Higashi, Japan; email: y.kanai@aist.go.jp; CODEN: JERAE},
}

