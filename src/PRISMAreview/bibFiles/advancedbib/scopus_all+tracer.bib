@article{zhang_7be_2014,
	title = {{7Be} atmospheric deposition flux determined from undisturbed soil},
	volume = {48},
	issn = {10006931 (ISSN)},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-84911472481&doi=10.7538%2fyzk.2014.48.09.1698&partnerID=40&md5=603b6d1d2def6da02fa7d9a7bd0f5327},
	doi = {10.7538/yzk.2014.48.09.1698},
	abstract = {Based on 7Be inventories in undisturbed soil and daily rainfall data, 7Be deposition flux was estimated in Yangling District, Shaanxi Province, China. The results show that there is no significant difference between the measured 7Be mean concentration and the estimated in rainfall, which demonstrates that it is reasonable to use 7Be inventories in undisturbed soil to estimate 7Be mean concentration in rainfall and then calculate 7Be deposition flux. Inter- and intra-annual variation of 7Be deposition flux is significant difference at the study site. The coefficient of variation for monthly 7Be deposition flux is 0.97. There is a marked seasonality in the seasonal values of 7Be deposition flux. Maximum value occurs in summer and minimum value occurs in winter. The annual 7Be deposition flux is 2 069 Bq/m2. The variation of 7Be inventory in undisturbed soil and 7Be deposition flux were determined by the precipitation amount and its temporal distribution. The strong linear correlation between 7Be deposition flux and precipitation amount is evident at different time scales. ©, 2014, Atomic Energy Press. All right reserved.},
	language = {Chinese},
