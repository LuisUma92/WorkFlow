Publisher: Nature Publishing Group},
	pages = {1--10},
	file = {Full Text PDF:/home/luis/Zotero/storage/M98AVMGE/Le Gall et al. - 2017 - Investigating the temporal dynamics of suspended s.pdf:application/pdf},
}

