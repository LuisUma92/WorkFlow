	keywords = {Vegetation, Sediment, Hydrology, Soil organic carbon, Plants, Water, Biomass, Groundwater, Remote sensing, Dissolved organic carbon, Lateral transport, Radiometric dating, Methane, Models, Accretion, Accumulation, Bulk density, Carbon cycling, Chambers, Core, Decomposition, Dissolved gas, Eddy covariance, Greenhouse gas, Incubation, Litter, Methods, Microbes, Net primary productivity, Porewater},
	pages = {1--169},
	annote = {Export Date: 08 March 2024; Cited By: 0; Correspondence Address: S. Bansal; U.S. Geological Survey, Northern Prairie Wildlife Research Center, Jamestown, United States; email: sbansal@usgs.gov},
