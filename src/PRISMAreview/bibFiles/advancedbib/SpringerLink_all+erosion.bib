@article{benoit_beryllium-7_2020,
	title = {Beryllium-7 {Elucidate} {Sediment} {Dynamics} of the {Branford} {River} {Estuary}, {Connecticut}, {USA}},
	volume = {43},
	copyright = {2020 Coastal and Estuarine Research Federation},
	issn = {1559-2731},
	url = {https://springerlink.proxyucr.elogim.com/article/10.1007/s12237-020-00712-5},
	doi = {10.1007/s12237-020-00712-5},
	abstract = {Berrylium-7 elucidates sediment dynamics (i.e., sources, sinks, deposition, and resuspension) in a Connecticut estuary. Average annual atmospheric deposition of 7Be is 290 mBq cm−2 year−1. Sediment samples from 43 locations within the estuary show that 7Be deposition is spatially complex, but were statistically indistinguishable a year apart. Weekly time series of sediments indicate that levels are nearly constant on this shorter time scale once radioactive decay is taken into account. 7Be levels in sediments are a balance between steady losses through radioactive decay and periodic pulse inputs following rainstorms. The water column was measured intensively during three rain events, showing that 7Be is removed rapidly from the water column, with a rate constant averaging 1.00 ± 0.12 day−1. A mass balance shows that 7Be is supplied about equally by direct precipitation onto the estuary’s surface and inflow from the watershed. Losses from the water column are split between net sedimentation (43\%) and tidal flushing (57\%). Variations in sedimentary 7Be levels at very short (meters) and longer (km) distances, and changes at time scales from hours to years, indicate that a large number of samples are required to capture all the variability in these highly dynamic systems. The current study differs from previous research in that a large number of measurements were conducted on a smaller system, and a full mass balance was developed.},
	language = {en},
	number = {4},
	urldate = {2024-02-19},
	journal = {Estuaries and Coasts},
	author = {Benoit, Gaboury and Hirschbeck, Matthew and Bisson, Beth},
	month = jun,
	year = {2020},
	note = {Company: Springer
Distributor: Springer
Institution: Springer
Label: Springer
Number: 4
Publisher: Springer US},
	pages = {831--842},
	file = {Full Text:/home/luis/Zotero/storage/A8SU92EF/Benoit et al. - 2020 - Beryllium-7 Elucidate Sediment Dynamics of the Bra.pdf:application/pdf;Full Text:/home/luis/Zotero/storage/C7LRFREQ/Benoit et al. - 2020 - Beryllium-7 Elucidate Sediment Dynamics of the Bra.pdf:application/pdf;Full Text PDF:/home/luis/Zotero/storage/YWRDFEAV/Benoit et al. - 2020 - Beryllium-7 Elucidate Sediment Dynamics of the Bra.pdf:application/pdf},
}

@article{taylor_estimating_2014,
	title = {Estimating {Be}-7 association with soil particle size fractions for erosion and deposition modelling},
	volume = {14},
	copyright = {2014 Springer-Verlag Berlin Heidelberg},
	issn = {1614-7480},
	url = {https://springerlink.proxyucr.elogim.com/article/10.1007/s11368-014-0955-8},
	doi = {10.1007/s11368-014-0955-8},
	abstract = {Purpose: Estimates of beryllium-7 (7Be) enrichment in soil particle size fractions are important for correction in existing soil redistribution models. Little attention has been given to documenting methods of estimating 7Be enrichment and assessing differences in enrichment between soil types in the context of soil redistribution modelling. Here, we detail a method for estimating 7Be enrichment and correcting soil redistribution estimates.; Materials and methods: Beryllium from a solution of BeCl2 was adsorbed to two soils with contrasting texture using a batch procedure. Soil fractions were separated by settling according to Stokes’ Law, and samples of bulk and settled fractions were digested and analysed for Be concentration and for specific surface area.; Results and discussion: Both soils demonstrated increasing enrichment of Be with increasing specific surface area. There was a marked difference in enrichment between the soil types with the coarse soil showing greater enrichment in the finer fractions. Calculated enrichment ratios for the coarse soil more than doubled between subfractions of the {\textless}63 μm class. Failure to account for the selective transport of fractions during soil redistribution studies could incur substantial errors in soil erosion estimates.; Conclusions: Stable Be provides a practical means of estimating 7Be enrichment in soil and subsequent corrections can be incorporated into the conversion model where it is proposed that corrections should be applied to the inventory deficit at each eroding point. The marked difference in enrichment between soil types in these experiments suggested that characterising enrichment and associated correction factors should be done on a site-specific basis. Implementation of the particle size correction procedures requires additional field and laboratory data to standard application of the established soil erosion conversion model. © 2014, Springer-Verlag Berlin Heidelberg.},
	language = {English},
	number = {11},
	urldate = {2024-02-19},
	journal = {Journal of Soils and Sediments},
	author = {Taylor, Alex and Blake, William H. and Keith-Roach, Miranda J.},
	month = nov,
	year = {2014},
	note = {Company: Springer
Distributor: Springer
Institution: Springer
Label: Springer
Number: 11
Publisher: Springer Berlin Heidelberg},
	keywords = {Beryllium-7, Correction, Particle size, Soil erosion model, Tracing},
	pages = {1886--1893},
	annote = {Export Date: 08 March 2024; Cited By: 19},
	annote = {Export Date: 08 March 2024; Cited By: 19},
	file = {Full Text PDF:/home/luis/Zotero/storage/ZDZJ8SCY/Taylor et al. - 2014 - Estimating Be-7 association with soil particle siz.pdf:application/pdf},
}

@article{naghdi_measuring_2024,
	title = {Measuring soil erosion rates in {Hyrcanian} forests: {An} application of the {137Cs} method},
	volume = {133},
	copyright = {2024 Indian Academy of Sciences},
	issn = {0973-774X},
	shorttitle = {Measuring soil erosion rates in {Hyrcanian} forests},
	url = {https://springerlink.proxyucr.elogim.com/article/10.1007/s12040-023-02239-2},
	doi = {10.1007/s12040-023-02239-2},
	abstract = {Forests play a crucial role in soil protection by helping to prevent erosion and runoff and can be highly effective in safeguarding soil. In this study, we evaluated soil erosion using the radionuclide method of 137Cs to examine spatial changes in soil erosion and to assess the impact of forestry projects on soil erosion in the Hyrcanian forests of northern Iran. Soil samples were collected up to a depth of 30 cm (the maximum penetration depth of cesium) in 2 cm layers using a scraper plate from various erosion intensities. These included untouched forest lands or reference sites, areas where tree cutting and single selection had been implemented, areas with pine and spruce afforestation projects, and landslide areas. Subsequent sampling was conducted with a coronal core in the studied regions, considering the area's length and topographic conditions. The samples were prepared in accordance with the instructions of the International Atomic Energy Agency (IAEA), and the amount of 137Cs was measured in the Atomic Energy Organization of Iran's laboratory. The average activity of 137Cs in reference sampling sites was measured at 1.589 Bq/m2. The erosion rate, loss percentage, and average annual soil loss in unharvested forest lands with strip cutting were 0.7 (ton/ha/yr), 0.8, and 0.3 mm, respectively. In contrast, the maximum soil erosion, loss percentage, and average loss en route to the site were estimated at 18.7 (ton/ha/yr), 19.1, and 0.7 mm. A map of soil erosion values was then prepared and compared with the estimated erosion values using the erosion plots method, highlighting the radionuclide method's capability to estimate erosion amounts and showcasing the significant effect of forest cover on soil protection, all while accurately estimating soil erosion across a broad area at a low cost.},
	language = {en},
	number = {1},
	urldate = {2024-02-19},
	journal = {Journal of Earth System Science},
	author = {Naghdi, Ramin and Zahedi, Shahriar Sobh and Gharibreza, Mohammadreza and Gholami, Vahid and Mirzaei, Mehrdad},
	month = feb,
	year = {2024},
	note = {Company: Springer
Distributor: Springer
Institution: Springer
Label: Springer
Number: 1
Publisher: Springer India},
	pages = {28},
	file = {Full Text PDF:/home/luis/Zotero/storage/PU7BJTGE/Naghdi et al. - 2024 - Measuring soil erosion rates in Hyrcanian forests.pdf:application/pdf},
}

@article{bansal_practical_2023,
	title = {Practical {Guide} to {Measuring} {Wetland} {Carbon} {Pools} and {Fluxes}},
	volume = {43},
	copyright = {2023 The Author(s)},
	issn = {0277-5212, 1943-6246},
	url = {https://springerlink.proxyucr.elogim.com/article/10.1007/s13157-023-01722-2},
	doi = {10.1007/s13157-023-01722-2},
	abstract = {Wetlands cover a small portion of the world, but have disproportionate influence on global carbon (C) sequestration, carbon dioxide and methane emissions, and aquatic C fluxes. However, the underlying biogeochemical processes that affect wetland C pools and fluxes are complex and dynamic, making measurements of wetland C challenging. Over decades of research, many observational, experimental, and analytical approaches have been developed to understand and quantify pools and fluxes of wetland C. Sampling approaches range in their representation of wetland C from short to long timeframes and local to landscape spatial scales. This review summarizes common and cutting-edge methodological approaches for quantifying wetland C pools and fluxes. We first define each of the major C pools and fluxes and provide rationale for their importance to wetland C dynamics. For each approach, we clarify what component of wetland C is measured and its spatial and temporal representativeness and constraints. We describe practical considerations for each approach, such as where and when an approach is typically used, who can conduct the measurements (expertise, training requirements), and how approaches are conducted, including considerations on equipment complexity and costs. Finally, we review key covariates and ancillary measurements that enhance the interpretation of findings and facilitate model development. The protocols that we describe to measure soil, water, vegetation, and gases are also relevant for related disciplines such as ecology. Improved quality and consistency of data collection and reporting across studies will help reduce global uncertainties and develop management strategies to use wetlands as nature-based climate solutions.},
	language = {English},
	number = {8},
	urldate = {2024-02-19},
	journal = {Wetlands},
	author = {Bansal, Sheel and Creed, Irena F. and Tangen, Brian A. and Bridgham, Scott D. and Desai, Ankur R. and Krauss, Ken W. and Neubauer, Scott C. and Noe, Gregory B. and Rosenberry, Donald O. and Trettin, Carl and Wickland, Kimberly P. and Allen, Scott T. and Arias-Ortiz, Ariane and Armitage, Anna R. and Baldocchi, Dennis and Banerjee, Kakoli and Bastviken, David and Berg, Peter and Bogard, Matthew J. and Chow, Alex T. and Conner, William H. and Craft, Christopher and Creamer, Courtney and DelSontro, Tonya and Duberstein, Jamie A. and Eagle, Meagan and Fennessy, M. Siobhan and Finkelstein, Sarah A. and Göckede, Mathias and Grunwald, Sabine and Halabisky, Meghan and Herbert, Ellen and Jahangir, Mohammad M. R. and Johnson, Olivia F. and Jones, Miriam C. and Kelleway, Jeffrey J. and Knox, Sara and Kroeger, Kevin D. and Kuehn, Kevin A. and Lobb, David and Loder, Amanda L. and Ma, Shizhou and Maher, Damien T. and McNicol, Gavin and Meier, Jacob and Middleton, Beth A. and Mills, Christopher and Mistry, Purbasha and Mitra, Abhijit and Mobilian, Courtney and Nahlik, Amanda M. and Newman, Sue and O’Connell, Jessica L. and Oikawa, Patty and van der Burg, Max Post and Schutte, Charles A. and Song, Changchun and Stagg, Camille L. and Turner, Jessica and Vargas, Rodrigo and Waldrop, Mark P. and Wallin, Marcus B. and Wang, Zhaohui Aleck and Ward, Eric J. and Willard, Debra A. and Yarwood, Stephanie and Zhu, Xiaoyan},
