Publisher: Science Press},
	pages = {1892--1908},
	file = {Full Text PDF:/home/luis/Zotero/storage/LVAHG7WF/Song et al. - 2018 - Features of soil redistribution and major element .pdf:application/pdf},
}

@article{valentin_principal_2015,
