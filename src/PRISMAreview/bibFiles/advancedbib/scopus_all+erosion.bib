}

@article{wan_natural_1987,
	title = {Natural ({210Pb}, {7Be}) and fallout ({137Cs}, 239,{240Pu}, {90Sr}) radionuclides as geochemical tracers of sedimentation in {Greifensee}, {Switzerland}},
