	pages = {487--519},
	annote = {Export Date: 08 March 2024; Cited By: 0; Correspondence Address: G. Matisoff; Department of Geological Sciences, Case Western Reserve University, Cleveland, 44106-7216, United States; email: gerald.matisoff@case.edu},
