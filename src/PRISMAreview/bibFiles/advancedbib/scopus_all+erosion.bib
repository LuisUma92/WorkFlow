	doi = {10.1016/B978-0-12-814395-7.00003-9},
	keywords = {Natural radionuclides, Accelerator mass spectrometry, Anthropogenic radionuclides, Chernobyl accident, Environmental radionuclides, Fukushima accident, Global fallout, Low-energy mass spectrometry, Radiometric methods, Radionuclide variations},
	pages = {137--261},
