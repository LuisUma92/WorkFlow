@incollection{filchev_modeling_2005,
	title = {Modeling of {Abiotic} {Stress} of {Conifers} with {Remote} {Sensing} {Data}},
	isbn = {978-1-119-78815-7},
	url = {https://doi.org/10.1002/9781119788157.ch4},
	abstract = {Summary This chapter discusses the different modeling approaches of abiotic stress in coniferous forests using remote sensing data. A detailed outlook with a background on stress, loads, and response of the conifers is provided to the readership. The chapter discusses the abiotic factors in two major groups; natural and anthropogenic. The natural abiotic factors are dealt with by natural components, i.e. soil chemical conditions. The anthropogenic factors affect almost all of the natural components; soil, atmosphere, and hydrosphere. Various aspects of atmospheric and soil pollution as well as ore extraction are provided with examples from numerous studies. The last part of the chapter is devoted to the critical loads and thresholds of various chemical constituents in soils and for conifers in specific. It also deals with the remote sensing methods and data used to discriminate them from space. Special attention is paid to the multi-band, hyperspectral, fluorescent, and thermal infrared satellite data which become more readily available to the Earth Observation community. The last part of the chapter is describing some of the most common models used in geosciences, ecology, and radiobiology which model the stress in vegetation and in conifers in particular.},
	urldate = {2024-03-08},
	booktitle = {Advances in {Remote} {Sensing} for {Forest} {Monitoring}},
	author = {Filchev, Lachezar},
	month = jun,
	year = {2005},
