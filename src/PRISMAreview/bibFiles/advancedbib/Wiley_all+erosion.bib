@article{field_urban_1985,
	title = {{URBAN} {RUNOFF}: {POLLUTION} {SOURCES}, {CONTROL}, {AND} {TREATMENT1}},
	volume = {21},
	issn = {9783527630134},
	url = {https://doi.org/10.1111/j.1752-1688.1985.tb00129.x},
	doi = {10.1111/j.1752-1688.1985.tb00129.x},
	abstract = {ABSTRACT This paper reviews progress on urban storm water management and pollution control, with emphasis on non- and low-structurally intensive techniques along with the total system approach encompassing control-treatment. Many of the U.S. Environmental Protection Agency's demonstration-evaluation projects are presented to exemplify: Land Management Techniques, i.e., land use planning, best use of natural drainage, dual use of retention and drainage facilities required for flood control designed concurrently or retrofitted for pollution control, porous pavement, surface sanitation, and chemical use control; Collection Systems Control, i.e., catchbasin cleaning, flow regulators (including swirl and helical devices), and the new concepts of elimination or reduction of unauthorized cross-connections, in-channel/conduit storage and/or other forms of storage for bleed-back to existing treatment plants; Storage including in-receiving water storage; Treatment, i.e., physical/chemical, disinfection, and a treatment-control planning and design guidebook; Sludge and Solids Residue from Treatment; and Integrated Systems, i.e., storage/treatment, dual-use wet-weather flow/dry-weather flow facilities, and reuse of stormwater for nonpotable purposes. Recommendations for the future in the areas of: control based on receiving water impacts, toxics characterization and their control, sewer system cross-connections, integrated stormwater management, and institutional/sociological/economic conflicts are also presented.},
	number = {2},
	urldate = {2024-03-08},
	journal = {JAWRA Journal of the American Water Resources Association},
	author = {Field, Richard},
	month = apr,
	year = {1985},
	note = {Publisher: John Wiley \& Sons, Ltd},
	keywords = {water quality, wastewater, combined sewers, storm sewer overflows, surface water runoff, urban runoff, waste treatment, water pollution},
	pages = {197--206},
}

@incollection{hirose_radioactive_2007,
	title = {Radioactive {Aerosols}: {Tracers} of {Atmospheric} {Processes}},
	isbn = {978-1-118-68255-5},
	url = {https://doi.org/10.1002/9781118682555.ch18},
	abstract = {Summary Radionuclides are emitted as gaseous and aerosol forms in the atmosphere. Gaseous radionuclides are converted to radioactive aerosols by attaching onto airborne particles. Radioactive aerosols have been traditionally studied as one of the most effective tracers to have better understanding of atmospheric processes of aerosols, such as gas-particle conversion, transport, wet and dry deposition and resuspension, because sources of radionuclides, being natural and anthropogenic, can be identified and radionuclides have their peculiar time scales. Recent studies of long-term observation of radioactive aerosols revealed that radioactive aerosols are a tracer of environmental change due to climate change. Especially, the Fukushima Daiichi nuclear power plant accident in 2011 recalled that atmospheric behaviors of radioactive aerosols and their fate are still current interest. In this Chapter, we focus origins of radioactive aerosols and their atmospheric behaviors including the Fukushima accident-derived radionuclides.},
