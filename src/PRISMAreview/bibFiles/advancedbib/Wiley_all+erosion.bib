@incollection{swarzenski_worldwide_2005,
	title = {On the {Worldwide} {Riverine} {Transport} of {Sediment} – {Associated} {Contaminants} to the {Ocean}},
	isbn = {978-0-470-84894-4},
	url = {https://doi.org/10.1002/0470848944.hsa090},
	abstract = {Abstract The continuous and persistent weathering of the continents and the ensuing transport of both eroded and anthropogenic products by rivers account for almost all the dissolved solutes, particulates, and sediment-associated contaminants delivered to the ocean. Transported within this riverine load are essential nutrients (e.g. P, N, C), (oxy)hydroxides of Fe/Mn that act as highly efficient riverine scavengers, an ever-changing suite of man-made organic and inorganic constituents, as well as a wide variety of natural solutes (e.g. Si, Ca, Mg, Sr). The environmental behavior of these river-borne constituents is controlled by dynamic phase partitioning between operationally defined dissolved, colloidal, and particulate pools control. As most trace elements are bound onto river particulates, their fate is defined foremost by the nonconservative nature of such solids as they move along the particle-size continuum or are exchanged and remobilized in river bed and floodplain sediments. This paper describes the global riverine transport of sediment-associated contaminants to the ocean.},
	urldate = {2024-03-08},
	booktitle = {Encyclopedia of {Hydrological} {Sciences}},
	author = {Swarzenski, Peter W and Campbell, Pamela L},
	month = oct,
	year = {2005},
	doi = {10.1002/0470848944.hsa090},
	keywords = {storage, remobilization, phase partitioning, redox cycling, river discharge, scavenging, sediment-associated contaminants, suspended sediment concentration},
	annote = {Major Reference Works},
}

@incollection{noauthor_public_2016,
	title = {Public {Radiation} {Exposures} and {Associated} {Issues}},
	isbn = {978-3-527-69435-8},
	url = {https://doi.org/10.1002/9783527694358.ch6},
	abstract = {Summary The radiation exposure incurred by aircrews and space tourists and the associated hazard of solar flares present a potential public health concern. These and other sources of radiation exposure affecting the public and their associated issues are addressed in this chapter. The chapter summarizes the low earth orbit (LEO) radiation environment by particle type, source of the particle, particle energy, and ability to penetrate an extravehicular activity (EVA) suit and the spacecraft. Dose limits are important considerations in communications with the public, in assessing nuclear emergencies, and in licensing procedures for new commercial power reactors. Risk communication involves information exchange between individuals, groups, and institutions. Public involvement in nuclear licensing is important for all facilities including power plants, industrial facilities using radioactive materials, and high-level waste storage facilities. Environmental protection is based on biological effects as the basis for determining doses for protection purposes.},
	urldate = {2024-03-08},
