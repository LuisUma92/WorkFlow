@incollection{noauthor_nuclear_2016,
	title = {Nuclear {Terrorist} {Events} {Including} {INDs} and {RDDs}},
	isbn = {978-3-527-69435-8},
	url = {https://doi.org/10.1002/9783527694358.ch4},
	abstract = {Summary Nuclear terrorist events, including sabotage, represent threats that utilize radioactive or special nuclear materials to disrupt society. This chapter considers a variety of radiological events caused by terrorist activities. Their effects on the public, emergency response actions and health physics response activities are addressed. Terrorists could utilize radiological dispersal devices (RDDs), radiation exposure devices (REDs), the deliberate contamination of food, water, or other consumables with radioactive materials, the dispersal of radioactive materials from fixed radiological or nuclear facilities or materials in transit and nuclear weapons and improvised nuclear devices (INDs) to accomplish their goals. The chapter discusses the relative hazards of the various event types and addresses the most serious terrorist threat that is the deployment of a nuclear device. Nuclear weapons pose a significant threat because their detonation produces massive destructive power with the subsequent dispersion of large quantities of radioactive materials.},
