@article{collins_sediment_2020,
	title = {Sediment source fingerprinting: benchmarking recent outputs, remaining challenges and emerging themes},
	volume = {20},
	copyright = {2020 The Author(s)},
	issn = {1614-7480},
	shorttitle = {Sediment source fingerprinting},
	url = {https://springerlink.proxyucr.elogim.com/article/10.1007/s11368-020-02755-4},
	doi = {10.1007/s11368-020-02755-4},
	abstract = {Purpose This review of sediment source fingerprinting assesses the current state-of-the-art, remaining challenges and emerging themes. It combines inputs from international scientists either with track records in the approach or with expertise relevant to progressing the science. Methods Web of Science and Google Scholar were used to review published papers spanning the period 2013–2019, inclusive, to confirm publication trends in quantities of papers by study area country and the types of tracers used. The most recent (2018–2019, inclusive) papers were also benchmarked using a methodological decision-tree published in 2017. Scope Areas requiring further research and international consensus on methodological detail are reviewed, and these comprise spatial variability in tracers and corresponding sampling implications for end-members, temporal variability in tracers and sampling implications for end-members and target sediment, tracer conservation and knowledge-based pre-selection, the physico-chemical basis for source discrimination and dissemination of fingerprinting results to stakeholders. Emerging themes are also discussed: novel tracers, concentration-dependence for biomarkers, combining sediment fingerprinting and age-dating, applications to sediment-bound pollutants, incorporation of supportive spatial information to augment discrimination and modelling, aeolian sediment source fingerprinting, integration with process-based models and development of open-access software tools for data processing. Conclusions The popularity of sediment source fingerprinting continues on an upward trend globally, but with this growth comes issues surrounding lack of standardisation and procedural diversity. Nonetheless, the last 2 years have also evidenced growing uptake of critical requirements for robust applications and this review is intended to signpost investigators, both old and new, towards these benchmarks and remaining research challenges for, and emerging options for different applications of, the fingerprinting approach.},
	language = {en},
	number = {12},
	urldate = {2024-02-19},
	journal = {Journal of Soils and Sediments},
	author = {Collins, Adrian L. and Blackwell, Martin and Boeckx, Pascal and Chivers, Charlotte-Anne and Emelko, Monica and Evrard, Olivier and Foster, Ian and Gellis, Allen and Gholami, Hamid and Granger, Steve and Harris, Paul and Horowitz, Arthur J. and Laceby, J. Patrick and Martinez-Carreras, Nuria and Minella, Jean and Mol, Lisa and Nosrati, Kazem and Pulley, Simon and Silins, Uldis and da Silva, Yuri Jacques and Stone, Micheal and Tiecher, Tales and Upadhayay, Hari Ram and Zhang, Yusheng},
