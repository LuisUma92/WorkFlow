Number: 12
Publisher: Science China Press},
	pages = {2017--2030},
	file = {Full Text PDF:/home/luis/Zotero/storage/9QNUAK76/Tang et al. - 2019 - Fingerprinting the sources of water-mobilized sedi.pdf:application/pdf},
}

