Publisher: Springer International Publishing},
	pages = {729--742},
	file = {Full Text PDF:/home/luis/Zotero/storage/S3TWN344/Frankl et al. - 2022 - Tracing hotspots of soil erosion in high mountain .pdf:application/pdf},
}

