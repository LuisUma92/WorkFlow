@article{yang_review_2023,
	title = {Review and prospect of soil compound erosion},
	volume = {15},
	copyright = {2023 The Author(s)},
	issn = {2194-7783},
	url = {https://springerlink.proxyucr.elogim.com/article/10.1007/s40333-023-0107-3},
	doi = {10.1007/s40333-023-0107-3},
	abstract = {Soil erosion is one of the most serious environmental issues constraining the sustainable development of human society and economies. Soil compound erosion is the result of the alternation or interaction between two or more erosion forces. In recent years, fluctuations and extreme changes in climatic factors (air temperature, precipitation, wind speed, etc.) have led to an increase in the intensity and extent of compound erosion, which is increasingly considered in soil erosion research. First, depending on the involvement of gravity, compound erosion process can be divided into compound erosion with and without gravity. We systematically summarized the research on the mechanisms and processes of alternating or interacting soil erosion forces (wind, water, and freeze-thaw) considering different combinations, combed the characteristics of compound erosion in three typical regions, namely, high-elevation areas, high-latitude areas, and dry and wet transition regions, and reviewed soil compound erosion research methods, such as station observations, simulation experiments, prediction models, and artificial neural networks. The soil erosion model of wind, water, and freeze-thaw interaction is the most significant method for quantifying and predicting compound erosion. Furthermore, it is proposed that there are several issues such as unclear internal mechanisms, lack of comprehensive prediction models, and insufficient scale conversion methods in soil compound erosion research. It is also suggested that future soil compound erosion mechanism research should prioritize the coupling of compound erosion forces and climate change.},
	language = {en},
	number = {9},
	urldate = {2024-02-19},
	journal = {Journal of Arid Land},
	author = {Yang, Wenqian and Zhang, Gangfeng and Yang, Huimin and Lin, Degen and Shi, Peijun},
	month = sep,
	year = {2023},
	note = {Company: Springer
Distributor: Springer
Institution: Springer
Label: Springer
Number: 9
Publisher: Science Press},
	pages = {1007--1022},
	file = {Full Text PDF:/home/luis/Zotero/storage/SKZGS2UE/Yang et al. - 2023 - Review and prospect of soil compound erosion.pdf:application/pdf},
}

@article{naghdi_measuring_2024,
	title = {Measuring soil erosion rates in {Hyrcanian} forests: {An} application of the {137Cs} method},
	volume = {133},
	copyright = {2024 Indian Academy of Sciences},
	issn = {0973-774X},
	shorttitle = {Measuring soil erosion rates in {Hyrcanian} forests},
	url = {https://springerlink.proxyucr.elogim.com/article/10.1007/s12040-023-02239-2},
	doi = {10.1007/s12040-023-02239-2},
	abstract = {Forests play a crucial role in soil protection by helping to prevent erosion and runoff and can be highly effective in safeguarding soil. In this study, we evaluated soil erosion using the radionuclide method of 137Cs to examine spatial changes in soil erosion and to assess the impact of forestry projects on soil erosion in the Hyrcanian forests of northern Iran. Soil samples were collected up to a depth of 30 cm (the maximum penetration depth of cesium) in 2 cm layers using a scraper plate from various erosion intensities. These included untouched forest lands or reference sites, areas where tree cutting and single selection had been implemented, areas with pine and spruce afforestation projects, and landslide areas. Subsequent sampling was conducted with a coronal core in the studied regions, considering the area's length and topographic conditions. The samples were prepared in accordance with the instructions of the International Atomic Energy Agency (IAEA), and the amount of 137Cs was measured in the Atomic Energy Organization of Iran's laboratory. The average activity of 137Cs in reference sampling sites was measured at 1.589 Bq/m2. The erosion rate, loss percentage, and average annual soil loss in unharvested forest lands with strip cutting were 0.7 (ton/ha/yr), 0.8, and 0.3 mm, respectively. In contrast, the maximum soil erosion, loss percentage, and average loss en route to the site were estimated at 18.7 (ton/ha/yr), 19.1, and 0.7 mm. A map of soil erosion values was then prepared and compared with the estimated erosion values using the erosion plots method, highlighting the radionuclide method's capability to estimate erosion amounts and showcasing the significant effect of forest cover on soil protection, all while accurately estimating soil erosion across a broad area at a low cost.},
	language = {en},
	number = {1},
	urldate = {2024-02-19},
	journal = {Journal of Earth System Science},
	author = {Naghdi, Ramin and Zahedi, Shahriar Sobh and Gharibreza, Mohammadreza and Gholami, Vahid and Mirzaei, Mehrdad},
	month = mar,
	year = {2024},
	note = {Company: Springer
Distributor: Springer
Institution: Springer
Label: Springer
Number: 1
Publisher: Springer India},
	pages = {1--16},
	file = {Full Text PDF:/home/luis/Zotero/storage/PU7BJTGE/Naghdi et al. - 2024 - Measuring soil erosion rates in Hyrcanian forests.pdf:application/pdf},
}

