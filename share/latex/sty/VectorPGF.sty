% --- Dependencias propias de la librería de estilos ---
\RequirePackage{tikz}
\usetikzlibrary{arrows.meta}

% --- Estilos TikZ para HD ---
\tikzset{
  line cap=round,
  line join=round,
  Vector/.style={
    -{Stealth[length=16pt,width=8pt]},
    line width=1.1pt
  },
  VectorAngle/.style={
    -{Latex[length=4pt,width=6pt]},
    line width=0.8pt
  },
  Axis/.style={
    ->,
    black,
    line width=0.9pt
  },
  Grids/.style={
    step=0.5cm,
    very thin,
    gray!30
  },
  Proyections/.style={
    dashed,
    line width=1.1pt
  }
}

% --- Estilos pgfplots reutilizables para ejes ---
% Convención de ejes: el SÍMBOLO de la variable va cerca del EXTREMO del eje
% (junto a la punta de la flecha), DEBAJO en el eje x y a la IZQUIERDA en el
% eje y; la UNIDAD va entre paréntesis tras el símbolo,
% p. ej. xlabel={\(r\) (m)}, ylabel={\(V\) (V)}.
% Requiere que pgfplots se cargue ANTES que VectorPGF (el guard lo verifica).
\@ifpackageloaded{pgfplots}{%
  \pgfplotsset{
    PhysAxis/.style={
      axis lines=left,
      axis line style={-{Stealth[length=10pt,width=6pt]}, line width=0.9pt},
      tick align=outside,
      xlabel style={at={(current axis.right of origin)},
                    anchor=north, yshift=-2pt},
      ylabel style={at={(current axis.above origin)},
                    anchor=east, rotate=-90, xshift=-2pt},
      every axis plot/.append style={line width=1.1pt},
    },
  }%
}{}%

\newcommand{\printvalue}[2]{
\pgfmathprintnumber[fixed,precision=#1]{#2}
}

\pgfmathsetmacro{\axisextra}{0.2}

\pgfmathsetmacro{\rtheta}{0.8}
\pgfmathsetmacro{\ralpha}{0.6}
\pgfmathsetmacro{\rbeta}{0.4}

% Vector A:
\pgfmathsetmacro{\Ax}{2}
\pgfmathsetmacro{\Ay}{1}
\pgfmathsetmacro{\Am}{sqrt(\Ax^2+\Ay^2)}
\pgfmathsetmacro{\At}{atan(\Ay/\Ax)}

% Vector B:
\pgfmathsetmacro{\Bx}{}
\pgfmathsetmacro{\By}{}
\pgfmathsetmacro{\Bm}{3}
\pgfmathsetmacro{\Bt}{60}
